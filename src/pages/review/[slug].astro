---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const reviews = await getCollection("reviews");
  return reviews.map((review) => ({
    params: { slug: review.slug },
    props: { review },
  }));
}

const { review } = Astro.props;
const { Content } = await review.render();
const d = review.data;
const catLabel = { pc: "Linh kiện PC", sach: "Sách", decor: "Decor" }[d.category];
const stars = "★".repeat(Math.round(d.rating)) + "☆".repeat(5 - Math.round(d.rating));
---
<BaseLayout title={d.title} description={d.description} image={d.image}>
  <article class="wrap art">
    <nav class="crumb">
      <a href="/">Trang chủ</a> › <a href={`/danh-muc/${d.category}`}>{catLabel}</a> › <span>{d.productName}</span>
    </nav>

    <span class={`badge b-${d.category}`}>{catLabel}</span>
    <h1>{d.title}</h1>
    <div class="head-meta">
      <span class="stars">{stars} <b>{d.rating}/5</b></span>
      <span class="price">{d.price}</span>
    </div>

    <img class="hero-img" src={d.image} alt={d.productName} />

    <!-- CTA mua hàng (link affiliate) -->
    <div class="cta">
      <a href={d.affiliateUrl} class="btn-buy" target="_blank" rel="nofollow sponsored noopener">
        🛒 Xem giá tốt nhất trên Shopee
      </a>
      <p class="cta-note">* Link tiếp thị — bạn không trả thêm phí, mình nhận hoa hồng nhỏ từ Shopee.</p>
    </div>

    <!-- Ưu / nhược -->
    <div class="proscons">
      <div class="pc-box pros">
        <h3>👍 Ưu điểm</h3>
        <ul>{d.pros.map((p) => <li>{p}</li>)}</ul>
      </div>
      <div class="pc-box cons">
        <h3>👎 Nhược điểm</h3>
        <ul>{d.cons.map((c) => <li>{c}</li>)}</ul>
      </div>
    </div>

    <!-- Nội dung bài (markdown) -->
    <div class="content"><Content /></div>

    <!-- CTA cuối bài -->
    <div class="cta cta-end">
      <h3>Chốt đơn nhanh kẻo hết khuyến mãi 👇</h3>
      <a href={d.affiliateUrl} class="btn-buy" target="_blank" rel="nofollow sponsored noopener">
        🛒 Mua {d.productName} trên Shopee
      </a>
    </div>
  </article>
</BaseLayout>

<style>
  .art { max-width: 760px; padding-top: 26px; }
  .crumb { font-size: 13px; color: var(--mut); margin-bottom: 14px; }
  .crumb a:hover { color: var(--text); }
  .art h1 { font-size: 30px; margin: 12px 0; line-height: 1.3; }
  .head-meta { display: flex; gap: 18px; align-items: center; margin-bottom: 18px; }
  .stars { color: var(--yellow); }
  .stars b { color: var(--text); }
  .price { color: var(--brand2); font-weight: 800; font-size: 20px; }
  .hero-img { width: 100%; border-radius: 14px; border: 1px solid var(--line); margin-bottom: 22px; }
  .cta { text-align: center; padding: 22px; background: var(--card);
    border: 1px solid var(--line); border-radius: 14px; margin: 22px 0; }
  .cta-note { font-size: 12px; color: var(--mut); margin-top: 10px; }
  .cta-end h3 { margin-bottom: 14px; }
  .proscons { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin: 22px 0; }
  .pc-box { background: var(--card); border: 1px solid var(--line); border-radius: 14px; padding: 16px 18px; }
  .pc-box h3 { font-size: 16px; margin-bottom: 10px; }
  .pc-box ul { list-style: none; }
  .pc-box li { padding: 5px 0 5px 20px; position: relative; font-size: 14px; color: #d4ddea; }
  .pros li::before { content: "✓"; position: absolute; left: 0; color: var(--green); font-weight: 700; }
  .cons li::before { content: "✕"; position: absolute; left: 0; color: var(--brand); font-weight: 700; }
  .content { font-size: 16px; color: #d8e1ee; }
  .content :global(h2) { font-size: 22px; margin: 26px 0 12px; }
  .content :global(h3) { font-size: 18px; margin: 20px 0 10px; }
  .content :global(p) { margin: 12px 0; }
  .content :global(ul) { margin: 12px 0 12px 22px; }
  .content :global(img) { border-radius: 12px; margin: 16px 0; }
  /* Khối sản phẩm trong bài: ảnh + nút mua Shopee */
  .content :global(.product) {
    display: flex; gap: 16px; align-items: center;
    background: var(--card); border: 1px solid var(--line);
    border-radius: 14px; padding: 14px; margin: 18px 0;
  }
  .content :global(.product img) {
    width: 130px; height: 130px; object-fit: cover; border-radius: 10px;
    margin: 0; flex-shrink: 0;
  }
  .content :global(.product .p-info) { flex: 1; min-width: 0; }
  .content :global(.product .p-info p) { margin: 0 0 12px; font-size: 14px; color: var(--mut); }
  .content :global(.btn-shopee) {
    display: inline-flex; align-items: center; gap: 7px;
    background: linear-gradient(135deg, var(--brand), var(--brand2));
    color: #fff; font-weight: 700; padding: 11px 20px; border-radius: 10px;
    font-size: 14px; box-shadow: 0 5px 16px rgba(238,77,45,.32); margin: 0;
  }
  .content :global(.btn-shopee:hover) { filter: brightness(1.08); }
  @media (max-width: 600px) {
    .proscons { grid-template-columns: 1fr; } .art h1 { font-size: 24px; }
    .content :global(.product) { flex-direction: column; align-items: stretch; text-align: center; }
    .content :global(.product img) { width: 100%; height: 180px; }
  }
</style>
